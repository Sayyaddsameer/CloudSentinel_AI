# CloudSentinel — Environment Variables Reference
# Copy this file to .env for local development.
# Never commit .env to Git. It is listed in .gitignore.
#
# These values are set as Lambda Environment Variables in AWS Console or Terraform.
# The frontend values are set in each HTML file under window.ENV_*.

# ─────────────────────────────────────────────
# SHARED — all Lambda functions
# ─────────────────────────────────────────────

# Name of the DynamoDB table storing all risk records
DYNAMODB_TABLE=cloudsentinel-risks

# AWS region where all services are deployed
AWS_REGION=us-east-1

# ─────────────────────────────────────────────
# CLOUD SCANNER — modules/cloud-infra/cloud_scanner.py
# ─────────────────────────────────────────────

# Optional: ARN of an IAM role to assume for cross-account scanning
# Leave empty to scan the Lambda's own account
TARGET_ROLE_ARN=

# Optional: Name of the Secrets Manager secret containing the GCP service account JSON
# Leave empty if not using GCP scanning
GCP_SECRET_NAME=cloudsentinel-gcp-credentials

# ─────────────────────────────────────────────
# AI EXPLAINER — modules/cloud-infra/ai_explainer.py
# ─────────────────────────────────────────────

# Amazon Bedrock model ID to use for AI explanations and chatbot
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Maximum tokens per Bedrock response (explanation length)
MAX_TOKENS=400

# Maximum number of risks to process per EventBridge trigger run
MAX_RISKS_PER_RUN=50

# ─────────────────────────────────────────────
# NOTIFICATION HANDLER — modules/cloud-infra/notification_handler.py
# ─────────────────────────────────────────────

# ARN of the SNS topic that delivers email alerts
# Format: arn:aws:sns:us-east-1:ACCOUNT_ID:cloudsentinel-alerts
SNS_TOPIC_ARN=

# Minimum risk priority level that triggers an email notification
# Accepted values: High | Medium | All
NOTIFICATION_THRESHOLD=High

# URL of the deployed Amplify frontend (included in alert emails)
APP_URL=https://your-app.amplifyapp.com

# ─────────────────────────────────────────────
# DEVOPS ANALYZER — modules/devops/devops_analyzer.py
# ─────────────────────────────────────────────

# Optional: ARN of the Secrets Manager secret containing the GitHub webhook secret
# Used to verify webhook payload signatures. Leave empty to skip verification.
WEBHOOK_SECRET_ARN=

# ─────────────────────────────────────────────
# FULLSTACK ANALYZER — modules/fullstack/fullstack_analyzer.py
# ─────────────────────────────────────────────

# API average latency threshold in milliseconds above which a risk is raised
LATENCY_THRESHOLD_MS=2000

# Number of 5XX errors per hour above which a risk is raised
ERROR_5XX_THRESHOLD=10

# Number of hours to look back when querying CloudWatch metrics
LOOKBACK_HOURS=1

# ─────────────────────────────────────────────
# DATA ENG ANALYZER — modules/data-eng/data_eng_analyzer.py
# ─────────────────────────────────────────────

# Number of Glue job failures (out of GLUE_RUNS_WINDOW runs) that trigger a High risk
GLUE_FAIL_THRESHOLD=2

# Number of most recent Glue job runs to inspect
GLUE_RUNS_WINDOW=5

# ─────────────────────────────────────────────
# MOBILE ANALYZER — modules/mobile/mobile_analyzer.py
# ─────────────────────────────────────────────

# API average latency threshold for mobile (stricter than fullstack: 1000ms vs 2000ms)
# LATENCY_THRESHOLD_MS=1000   (same variable name — set per Lambda)

# Number of 4XX errors per hour above which a risk is raised
ERROR_4XX_THRESHOLD=50

# Number of Lambda function errors per hour above which a risk is raised
LAMBDA_ERROR_THRESHOLD=5

# ─────────────────────────────────────────────
# FRONTEND — modules/frontend/*.html
# Set via window.ENV_* at the top of each HTML file
# ─────────────────────────────────────────────

# Cognito User Pool ID — from Terraform output: cognito_user_pool_id
ENV_COGNITO_POOL_ID=us-east-1_XXXXXXXXX

# Cognito App Client ID — from Terraform output: cognito_client_id
ENV_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# API Gateway Invoke URL — from Terraform output: api_invoke_url
ENV_API_URL=https://XXXX.execute-api.us-east-1.amazonaws.com/dev

# AWS region for Cognito SDK calls
ENV_REGION=us-east-1

# ─────────────────────────────────────────────
# TERRAFORM — infrastructure/terraform/terraform.tfvars
# These are Terraform input variables, not Lambda env vars
# ─────────────────────────────────────────────

# TF_VAR_aws_region=us-east-1
# TF_VAR_project=cloudsentinel
# TF_VAR_environment=dev
# TF_VAR_alert_email=your-email@domain.com
# TF_VAR_app_url=https://your-app.amplifyapp.com
# TF_VAR_gcp_secret_name=cloudsentinel-gcp-credentials
# TF_VAR_target_role_arn=
# TF_VAR_github_token=
# TF_VAR_webhook_secret_arn=
