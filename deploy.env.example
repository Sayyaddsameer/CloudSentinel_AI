# deploy.env — CloudSentinel console deployer configuration
# ---------------------------------------------------------------------------
# Copy this file as deploy.env and fill in the values before running
# python deploy_console.py
#
# Alternatively, export each variable as CS_* environment variables in your
# shell session. Environment variables take precedence over this file.
#
# Never commit deploy.env to version control. It is listed in .gitignore.
# ---------------------------------------------------------------------------

# AWS region where all CloudSentinel resources will be deployed.
CS_REGION=us-east-1

# Short identifier used as a prefix on every resource name and tag.
CS_PROJECT=cloudsentinel

# Deployment environment label applied to resource tags.
CS_ENVIRONMENT=dev

# Email address that receives SNS risk alert notifications.
# The recipient must confirm the AWS subscription link before alerts are sent.
CS_ALERT_EMAIL=your-email@domain.com

# Public URL of the deployed frontend. Leave empty if not yet known.
CS_APP_URL=

# Amazon Bedrock model ID for the AI explainer and chatbot functions.
# Enable the model first in the AWS console under Bedrock > Model access.
CS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Minimum risk priority that triggers an alert email: High | Medium | All
CS_NOTIFICATION_THRESHOLD=High

# Tuning parameters — change only if needed
CS_MAX_TOKENS=400
CS_MAX_RISKS_PER_RUN=50
CS_RISKS_PAGE_LIMIT=100
CS_CHATBOT_CONTEXT_RISKS=20

# Optional: GCP service account secret name in AWS Secrets Manager
# Leave empty to disable GCP scanning
CS_GCP_SECRET_NAME=

# Optional: IAM role ARN for cross-account scanning
# Leave empty to scan the deployer's own account
CS_TARGET_ROLE_ARN=
